{
  "name": "vue-demo",
  "projectType": "application",
  "root": "apps/vue-demo",
  "sourceRoot": "apps/vue-demo/src",
  "targets": {
    "serve": {
      "executor": "@nx/vite:dev-server",
      "options": {
        "buildTarget": "vue-demo:build",
        "hmr": true,
        "port": 4201
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/vue-demo",
        "configFile": "apps/vue-demo/vite.config.ts"
      }
    }
  }
}
